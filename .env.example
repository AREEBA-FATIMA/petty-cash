# ─────────────────────────────────────────
# Petty Cash System — Environment Variables
# cp .env.example .env  karke values fill karo
# ─────────────────────────────────────────

# Django
SECRET_KEY=django-super-secret-key-change-this-in-production
DEBUG=True

# Database
DB_NAME=petty_cash_db
DB_USER=postgres
DB_PASSWORD=postgres123

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# pgAdmin (docker compose --profile tools up)
PGADMIN_EMAIL=admin@petty.cash
PGADMIN_PASSWORD=admin123
